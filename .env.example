LOCAL_DATA_DIR=.mytradebook-data
PORT=5000
# Optional fallback for deep intraday history when Yahoo cannot serve the range
TWELVE_DATA_API_KEY=your-twelvedata-api-key
# Grok AI settings for trading coaching suggestions
GROK_API_KEY=your-grok-api-key
GEMINI_API_KEY=your-gemini-api-key
# CoinMarketCap listings for crypto charts
CMC_API_KEY=your-coinmarketcap-api-key
CMC_CACHE_MAX=1000
MAX_UPLOAD_SIZE_MB=10
WEBHOOK_RATE_LIMIT_MAX=120
MAX_STARTING_BALANCE=1000000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=tradebook-uploads
SUPABASE_STATE_TABLE=app_state
SUPABASE_STATE_KEY=global
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional overrides
# GROK_MODEL=grok-4
# GEMINI_MODEL=gemini-2.5-flash
# GROK_API_URL=https://api.x.ai/v1/chat/completions
# CRYPTO_SALT=change-this-to-a-strong-random-value
